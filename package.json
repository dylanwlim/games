{
  "name": "dylan-games",
  "version": "0.1.0",
  "private": true,
  "description": "Premium browser-games hub for games.dylanwlim.com.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "validate": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build && npm run test:e2e",
    "verify:deployment": "node scripts/verify-deployment.mjs",
    "deploy:preview": "vercel deploy",
    "deploy:production": "vercel deploy --prod"
  },
  "engines": {
    "node": "24.x",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "postcss": "^8.5.15"
  },
  "dependencies": {
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
